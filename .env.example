# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.

# AISStream.io — free WebSocket AIS feed
# Sign up at https://aisstream.io/ to get a key
AISSTREAM_API_KEY=your_aisstream_key_here

# NewsAPI — free tier (100 req/day)
# Sign up at https://newsapi.org/ to get a key
NEWS_API_KEY=your_newsapi_key_here

# Ollama — local, no key needed
# Ensure Ollama is running: `ollama serve`
# Pull the model:           `ollama pull qwen2.5:7b`
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# Safety net: max tool calls per agent run, in case the model over-calls tools
AGENT_TOOL_CALLS_LIMIT=20
